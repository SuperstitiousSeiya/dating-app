{
  "name": "@dating-app/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "cd ../.. && (cd packages/utils && bun run build) && (cd packages/validators && bun run build) && cd apps/backend && nest start --watch",
    "build": "tsc -p tsconfig.build.json",
    "clean:maps": "bunx rimraf \".build/**/*.map\"",
    "start": "node .build/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dating-app/types": "workspace:*",
    "@dating-app/validators": "workspace:*",
    "@dating-app/utils": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^10.0.4",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.1",
    "@nestjs/websockets": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.2.0",
    "expo-server-sdk": "^3.10.0",
    "@fastify/cookie": "^8.3.0",
    "@fastify/multipart": "^7.7.0",
    "fastify": "^4.29.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "mongoose": "^8.3.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "resend": "^3.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "stripe": "^15.5.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@dating-app/config-typescript": "workspace:*",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "@types/multer": "^1.4.11",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^1.5.0",
    "supertest": "^7.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
