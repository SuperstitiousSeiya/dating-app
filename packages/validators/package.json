{
  "name": "@dating-app/validators",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.validator.d.ts",
      "default": "./dist/auth.validator.js"
    },
    "./profile": {
      "types": "./dist/profile.validator.d.ts",
      "default": "./dist/profile.validator.js"
    },
    "./swipe": {
      "types": "./dist/swipe.validator.d.ts",
      "default": "./dist/swipe.validator.js"
    },
    "./message": {
      "types": "./dist/message.validator.d.ts",
      "default": "./dist/message.validator.js"
    },
    "./match": {
      "types": "./dist/match.validator.d.ts",
      "default": "./dist/match.validator.js"
    },
    "./notification": {
      "types": "./dist/notification.validator.d.ts",
      "default": "./dist/notification.validator.js"
    },
    "./media": {
      "types": "./dist/media.validator.d.ts",
      "default": "./dist/media.validator.js"
    },
    "./pagination": {
      "types": "./dist/pagination.validator.d.ts",
      "default": "./dist/pagination.validator.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "bunx rimraf dist",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@dating-app/config-typescript": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
