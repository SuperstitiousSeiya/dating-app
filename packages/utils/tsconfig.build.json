{
  "extends": "@dating-app/config-typescript/base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "typeRoots": ["../../types", "../../node_modules/@types"],
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "verbatimModuleSyntax": false
  },
  "include": ["src"]
}

